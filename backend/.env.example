# ─── ChatFlow CRM — Environment Variables ─────────────────────
# Copy this file to .env and fill in your values

# ─── General ───────────────────────────────────────────────────
ENV=development
# Set to "production" to hide /docs, enable HSTS, etc.

SECRET_KEY=your-secret-key-change-this-in-production
REFRESH_SECRET_KEY=your-refresh-secret-key-change-this

# CORS — comma-separated origins (use * for dev)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── WhatsApp Cloud API ───────────────────────────────────────
# Get these from Meta Developer Console → Your App → WhatsApp → API Setup

# Permanent System User token (never expires)
WHATSAPP_TOKEN=

# Webhook verification token (you choose this, must match Meta webhook config)
WHATSAPP_VERIFY_TOKEN=chatflow_verify_2024

# ─── Phone Numbers (Multi-Number Setup) ──────────────────────
# Comma-separated phone_number_ids from WhatsApp Manager
WHATSAPP_PHONE_IDS=PHONE_ID_1,PHONE_ID_2

# Display names for each number
WHATSAPP_PHONE_NAME_PHONE_ID_1=יש לי זכות - מספר 1
WHATSAPP_PHONE_NAME_PHONE_ID_2=יש לי זכות - מספר 2

# ─── Single Number Setup (alternative to multi-number) ────────
# WHATSAPP_PHONE_ID=YOUR_PHONE_NUMBER_ID
# WHATSAPP_PHONE_NAME=יש לי זכות
